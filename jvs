  t  => `Dev just burned LP on ${t}. Bullish AF. NFA`,
  t  => `Sniped ${t} at launch. Still early. Chart looks clean 📈`,
  (ca,t) => `${t} just dropped! CA: ${ca} This is it lads 🤝`,
];

function simulateTweet(handle) {
  const ca     = FAKE_POOLS[Math.floor(Math.random() * FAKE_POOLS.length)];
  const ticker = FAKE_TICKERS[Math.floor(Math.random() * FAKE_TICKERS.length)];
  const tpl    = TEMPLATES[Math.floor(Math.random() * TEMPLATES.length)];
  return tpl(ca, ticker);
}

/* ============================================================
   ── BACKEND INTEGRATION NOTES ──────────────────────────────

   To use REAL Twitter data, you need a backend proxy because:
   1. Twitter API keys must NEVER be exposed in the browser.
   2. Twitter API v2 requires OAuth 2.0 Bearer Token.

   SETUP:
   -------
   1. Apply for Twitter Developer access at developer.twitter.com
   2. Create a project + app, get your Bearer Token.
   3. Create a simple backend endpoint, e.g. Node.js/Express:

   GET /api/tweets/:handle
   ┌─────────────────────────────────────────────────────────┐
   │ const res = await fetch(                                │
   │   `https://api.twitter.com/2/tweets/search/recent`+    │
   │   `?query=from:${handle}&max_results=10`,              │
   │   { headers: {                                          │
   │       Authorization: `Bearer ${process.env.TW_TOKEN}`  │
   │   }}                                                    │
   │ );                                                      │
   │ const data = await res.json();                          │
   │ return data.data || [];                                 │
   └─────────────────────────────────────────────────────────┘

   4. In this file, replace simulateTweet with:

   async function fetchRealTweets(handle) {
     const res = await fetch(`/api/tweets/${handle}`);
     const tweets = await res.json();
     return tweets.map(t => t.text);
   }

   And in runScan():
   const tweets = await fetchRealTweets(account.handle);
   tweets.forEach(text => processTweet(account.handle, text));

   ============================================================ */
  { text: '$WIF $BONK $POPCAT all going parabolic rn don\'t miss this window', handle: 'solanamaxi' },
];

function simulateDetection() {
  const sample = DEMO_SAMPLES[Math.floor(Math.random() * DEMO_SAMPLES.length)];
  const handle = state.accounts.length > 0
    ? state.accounts[Math.floor(Math.random() * state.accounts.length)].handle
    : sample.handle;

  showToast(⚡ Simulating detection from @${handle});
  detectInText(sample.text, handle);

  // Update hit count
  const acc = state.accounts.find(a => a.handle === handle);
  if (acc) { acc.hits++; saveAccounts(); renderAccounts(); }
}


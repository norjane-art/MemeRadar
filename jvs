// ── ALERT MODAL + PUSH NOTIFICATIONS ──────────────────
function triggerAlert(handle, ca, caType, kind) {
  // In-app modal
  state.currentModal = { handle, ca, caType };
  modalHandle.textContent = @${handle};
  modalCA.textContent = ca;
  modalType.textContent = Type: ${caType} (${kind}) — tap a platform below to open;
  modalOverlay.classList.add('show');

  // Update status
  statusDot.className = 'status-dot alert';
  statusText.textContent = 'ALERT!';
  setTimeout(() => {
    statusDot.className = status-dot ${state.polling ? 'active' : ''};
    statusText.textContent = state.polling ? 'LIVE' : 'IDLE';
  }, 5000);

  // Push notification
  if (state.notifEnabled && 'Notification' in window && Notification.permission === 'granted') {
    const n = new Notification(🚨 @${handle} posted a ${caType}!, {
      body: ${ca}\nTap to open MemeRadar,
      icon: 'https://dexscreener.com/favicon.ico',
      tag: mr-${handle}-${ca},
      renotify: true,
    });
    n.onclick = () => { window.focus(); };
  }

  showToast🚨 @${handle} posted a ${caType}!`);
}

function closeModal() {
  modalOverlay.classList.remove('show');
}

// ── NOTIFICATIONS ──────────────────────────────────────
async function toggleNotifications() {
  if (state.notifEnabled) {
    state.notifEnabled = false;
    notifToggle.classList.remove('active');
    notifLabel.textContent = 'NOTIFICATIONS OFF';
    showToast('Push notifications disabled.');
    return;
  }

  if (!('Notification' in window)) {
    showToast('Browser does not support notifications.', true); return;
  }

  if (Notification.permission === 'denied') {
    showToast('Notifications blocked. Allow in browser settings.', true); return;
  }

  if (Notification.permission !== 'granted') {
    const perm = await Notification.requestPermission();
    if (perm !== 'granted') {
      showToast('Notification permission denied.', true); return;
    }
  }

  state.notifEnabled = true;
  notifToggle.classList.add('active');
  notifLabel.textContent = 'NOTIFICATIONS ON';
  showToast('🔔 Push notifications enabled!');

  // Test notification
  new Notification('MemeRadar Active', {
    body: 'You will be notified when a CA or ticker is detected.',
    icon: 'https://dexscreener.com/favicon.ico',
  });
}

// ── DEX OPENERS ────────────────────────────────────────
function openDex(platform) {
  const ca = caInput.value.trim();
  if (!ca) { showToast('Enter a CA or ticker first.', true); return; }
  openDexWith(platform, ca);
}

function openDexFromModal(platform) {
  if (!state.currentModal) return;
  openDexWith(platform, state.currentModal.ca);
}

function openDexWith(platform, ca) {
  const url = DEX_URLS[platform];
  if (!url) return;
  window.open(url(ca), '_blank', 'noopener');
}

function quickOpen(ca) {
  openDexWith('dexscreener', ca);
}

// ── STATUS ─────────────────────────────────────────────
function updateStatus() {
  if (state.accounts.length === 0) {
    statusDot.className = 'status-dot';
    statusText.textContent = 'IDLE';
  } else if (state.polling) {
    statusDot.className = 'status-dot active';
    statusText.textContent = 'LIVE';
  }
}

// ── TICKER BAR ─────────────────────────────────────────
function updateTickerBar() {
  const recent = [...state.detected].reverse().slice(0, 10);
  if (recent.length === 0) return;
  tickerInner.textContent = recent
    .map(d => ${d.type}: ${d.value} (@${d.handle}))
    .join('   ——   ');
}

// ── TOAST ─────────────────────────────────────────────
let toastTimer;
function showToast(msg, isError = false) {
  toast.textContent = msg;
  toast.className = toast show${isError ? ' error' : ''};
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { toast.className = 'toast'; }, 3000);
}

// ── PERSISTENCE ────────────────────────────────────────
function saveAccounts() { localStorage.setItem('mr_accounts', JSON.stringify(state.accounts)); }
function saveDetected()  { localStorage.setItem('mr_detected', JSON.stringify(state.detected)); }

// ── UTILS ──────────────────────────────────────────────
function escHtml(str) {
  return String(str)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;')
    .replace(/'/g,'&#39;');
}

// ── EXPOSE GLOBALS (for inline onclick) ────────────────
window.removeAccount   = removeAccount;
window.openDex         = openDex;
window.openDexFromModal= openDexFromModal;
window.openDexWith     = openDexWith;
window.quickOpen       = quickOpen;

// ── START ──────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', init);

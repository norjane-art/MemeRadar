// ── STATE ──────────────────────────────────────────────────
const state = {
  tracked: [],          // { handle, addedAt }
  feedItems: [],        // all detected signals
  filter: 'all',        // all | ca | ticker
  scanInterval: 30,     // seconds
  scanTimer: null,
  notifGranted: false,
};

// ── DOM REFS ───────────────────────────────────────────────
const $ = id => document.getElementById(id);
const twitterInput = $('twitterInput');
const trackBtn     = $('trackBtn');
const trackedList  = $('trackedList');
const trackCount   = $('trackCount');
const feed         = $('feed');
const statusBadge  = $('statusBadge');
const statusText   = $('statusText');
const notifBtn     = $('notifBtn');
const dexInput     = $('dexInput');
const dexSearchBtn = $('dexSearchBtn');
const alertModal   = $('alertModal');
const modalBody    = $('modalBody');
const modalActions = $('modalActions');
const modalClose   = $('modalClose');
const toastContainer = $('toastContainer');

// ── DEX TRADING LINKS ──────────────────────────────────────
const TRADING_LINKS = [
  { name: '📊 DexScreener', url: ca => `https://dexscreener.com/search?q=${ca}` },
  { name: '🧬 GMGN.AI',     url: ca => `https://gmgn.ai/sol/token/${ca}` },
  { name: '⚡ Axiom',        url: ca => `https://axiom.trade/token/${ca}` },
  { name: '👻 Phantom',      url: ca => `https://phantom.app/ul/v1/browse/https://dexscreener.com/search?q=${ca}` },
  { name: '🪐 Jupiter',      url: ca => `https://jup.ag/swap/SOL-${ca}` },
  { name: '☀️ Raydium',      url: ca => `https://raydium.io/swap/?outputCurrency=${ca}` },
  { name: '🤖 Terminal',     url: ca => `https://t.me/terminaltrade_bot?start=${ca}` },
  { name: '🔨 BonkBot',      url: ca => `https://t.me/bonkbot_bot?start=${ca}` },
];

// CA patterns: Solana (44 chars base58) / ETH (0x...)
const CA_REGEX     = /\b([1-9A-HJ-NP-Za-km-z]{32,44}|0x[a-fA-F0-9]{40})\b/g;
const TICKER_REGEX = /\$([A-Z]{2,10})\b/g;

// ── INIT ───────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  loadState();
  bindEvents();
  renderTrackedList();
  if (state.tracked.length > 0) startScanning();
});

// ── BIND EVENTS ────────────────────────────────────────────
function bindEvents() {
  trackBtn.addEventListener('click', addAccount);
  twitterInput.addEventListener('keydown', e => { if (e.key === 'Enter') addAccount(); });

  notifBtn.addEventListener('click', requestNotifications);

  // Feed filters
  $('feedAll').addEventListener('click', () => setFilter('all'));
  $('feedCA').addEventListener('click', () => setFilter('ca'));
  $('feedTicker').addEventListener('click', () => setFilter('ticker'));

  // Scan interval
  document.querySelectorAll('.interval-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.interval-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      state.scanInterval = parseInt(this.dataset.val);
      if (state.scanTimer) { restartScanning(); }
      toast('info', '⏱ Interval Updated', `Scan every ${formatInterval(state.scanInterval)}`);
    });
  });

  // DEX quick search
  dexSearchBtn.addEventListener('click', quickDexSearch);
  dexInput.addEventListener('keydown', e => { if (e.key === 'Enter') quickDexSearch(); });

  // Modal close
  modalClose.addEventListener('click', () => alertModal.style.display = 'none');
  alertModal.addEventListener('click', e => { if (e.target === alertModal) alertModal.style.display = 'none'; });
}

// ── ADD ACCOUNT ────────────────────────────────────────────
function addAccount() {
  let handle = twitterInput.value.trim().replace(/^@/, '').toLowerCase();
  if (!handle) { toast('warn', '⚠ Input Required', 'Enter a Twitter @ handle.'); return; }
  if (!/^[a-z0-9_]{1,50}$/i.test(handle)) { toast('warn', '⚠ Invalid Handle', 'Only letters, numbers, underscores.'); return; }
  if (state.tracked.find(t => t.handle === handle)) {
    toast('warn', '⚠ Already Tracked', `@${handle} is already in your list.`); return;
  }

  state.tracked.push({ handle, addedAt: Date.now() });
  saveState();
  renderTrackedList();
  twitterInput.value = '';
  toast('success', '✓ Account Added', `Now tracking @${handle}`);

  if (state.tracked.length === 1) startScanning();
}

// ── REMOVE ACCOUNT ─────────────────────────────────────────
function removeAccount(handle) {
  state.tracked = state.tracked.filter(t => t.handle !== handle);
  saveState();
  renderTrackedList();
  toast('info', 'Account Removed', `@${handle} removed.`);
  if (state.tracked.length === 0) stopScanning();
}

// ── RENDER TRACKED LIST ────────────────────────────────────
function renderTrackedList() {
  trackCount.textContent = state.tracked.length;
  if (state.tracked.length === 0) {
    trackedList.innerHTML = '<div class="empty-state">No accounts tracked yet.</div>';
    return;
  }
  trackedList.innerHTML = state.tracked.map(t => `
    <div class="tracked-item">
      <span class="ti-name">@${t.handle}</span>
      <span class="ti-status">● LIVE</span>
      <button class="ti-remove" onclick="removeAccount('${t.handle}')" title="Remove">✕</button>
    </div>
  `).join('');
}

// ── SCANNING ENGINE ────────────────────────────────────────
function startScanning() {
  if (state.scanTimer) clearInterval(state.scanTimer);
  setStatus('live');
  runScan(); // immediate first scan
  state.scanTimer = setInterval(runScan, state.scanInterval * 1000);
}

function stopScanning() {
  clearInterval(state.scanTimer);
  state.scanTimer = null;
  setStatus('offline');
}

function restartScanning() {
  stopScanning();
  if (state.tracked.length > 0) startScanning();
}

// ── SCAN LOGIC ─────────────────────────────────────────────
// In production: replace simulateTweet() with a call to your backend proxy
// that calls the Twitter API (v2 /tweets/search/recent or user timeline).
async function runScan() {
  if (state.tracked.length === 0) return;
  setStatus('live');

  for (const account of state.tracked) {
    // ── PRODUCTION HOOK ──────────────────────────────────
    // const tweets = await fetchRealTweets(account.handle);
    // processTweets(account.handle, tweets);
    // ────────────────────────────────────────────────────

    // Simulation: random chance to generate a signal
    if (Math.random() < 0.30) {   // 30% hit per account per scan
      const tweet = simulateTweet(account.handle);
      processTweet(account.handle, tweet);
    }
  }
}

// ── PROCESS TWEET ──────────────────────────────────────────
function processTweet(handle, tweet) {
  const caMatches     = [...tweet.matchAll(CA_REGEX)].map(m => m[1]);
  const tickerMatches = [...tweet.matchAll(TICKER_REGEX)].map(m => m[1]);

  if (caMatches.length === 0 && tickerMatches.length === 0) return;

  const item = {
    id: Date.now() + Math.random(),
    handle,
    tweet,
    caMatches,
    tickerMatches,
    timestamp: new Date(),
    type: caMatches.length > 0 ? 'ca' : 'ticker',
  };

  state.feedItems.unshift(item);
  saveState();
  renderFeed();

  // Notification
  const label = caMatches.length > 0
    ? `CA: ${caMatches[0].slice(0,12)}…`
    : `$${tickerMatches[0]}`;

  toast('danger', `🚨 @${handle} posted!`, label);
  triggerModal(item);
  sendPushNotification(handle, label, tweet);
}

// ── RENDER FEED ────────────────────────────────────────────
function renderFeed() {
  let items = state.feedItems;
  if (state.filter === 'ca')     items = items.filter(i => i.type === 'ca');
  if (state.filter === 'ticker') items = items.filter(i => i.type === 'ticker');

  if (items.length === 0) {
    feed.innerHTML = `
      <div class="feed-empty">
        <div class="radar-anim">◎</div>
        <p>Awaiting signal...</p>
      </div>`;
    return;
  }

  feed.innerHTML = items.slice(0, 60).map(item => {
    const highlighted = highlightContent(item.tweet, item.caMatches, item.tickerMatches);
    const badgeType   = item.type === 'ca' ? 'ca' : 'ticker';
    const badgeLabel  = item.type === 'ca' ? '◈ CONTRACT ADDRESS' : '◇ TICKER';
    const timeStr     = formatTime(item.timestamp);

    // Action buttons per CA
    const actionBtns = item.caMatches.slice(0, 1).map(ca =>
      TRADING_LINKS.map(link => `
        <a href="${link.url(ca)}" target="_blank" class="fc-action-btn">${link.name}</a>
      `).join('')
    ).join('') + item.tickerMatches.slice(0, 1).map(ticker => `
        <a href="https://dexscreener.com/search?q=${ticker}" target="_blank" class="fc-action-btn">📊 Search $${ticker}</a>
        <a href="https://gmgn.ai/sol/token/${ticker}" target="_blank" class="fc-action-btn">🧬 GMGN $${ticker}</a>
    `).join('');

    return `
      <div class="feed-card type-${item.type}">
        <div class="fc-header">
          <span class="fc-account">@${item.handle}</span>
          <span class="fc-time">${timeStr}</span>
        </div>
        <span class="fc-badge ${badgeType}">${badgeLabel}</span>
        <div class="fc-content">${highlighted}</div>
        <div class="fc-actions">${actionBtns}</div>
      </div>
    `;
  }).join('');
}

function highlightContent(text, cas, tickers) {
  let out = escapeHtml(text);
  cas.forEach(ca => {
    out = out.replace(escapeHtml(ca), `<span class="highlight-ca">${escapeHtml(ca)}</span>`);
  });
  tickers.forEach(t => {
    out = out.replace(`$${t}`, `<span class="highlight-ticker">$${t}</span>`);
  });
  return out;
}

function escapeHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── FILTER ─────────────────────────────────────────────────
function setFilter(f) {
  state.filter = f;
  document.querySelectorAll('.feed-ctrl-btn').forEach(b => b.classList.remove('active'));
  const map = { all: 'feedAll', ca: 'feedCA', ticker: 'feedTicker' };
  $(map[f]).classList.add('active');
  renderFeed();
}

// ── MODAL ──────────────────────────────────────────────────
function triggerModal(item) {
  modalBody.innerHTML = `
    <div style="margin-bottom:10px; color:#aac;">Account: <span style="color:var(--accent)">@${item.handle}</span></div>
    ${item.caMatches.length ? `<div style="margin-bottom:6px;">Contract Address:<br><span style="color:var(--success)">${item.caMatches[0]}</span></div>` : ''}
    ${item.tickerMatches.length ? `<div style="margin-bottom:6px;">Ticker: <span style="color:var(--gold)">$${item.tickerMatches[0]}</span></div>` : ''}
    <div style="margin-top:10px; color:var(--text-dim); font-size:11px;">${escapeHtml(item.tweet)}</div>
  `;

  const ca = item.caMatches[0] || item.tickerMatches[0] || '';
  modalActions.innerHTML = TRADING_LINKS.map(link => `
    <a href="${link.url(ca)}" target="_blank" class="modal-action-btn">${link.name}</a>
  `).join('');

  alertModal.style.display = 'flex';
  setTimeout(() => { if (alertModal.style.display === 'flex') alertModal.style.display = 'none'; }, 12000);
}

// ── PUSH NOTIFICATIONS ─────────────────────────────────────
function requestNotifications() {
  if (!('Notification' in window)) {
    toast('warn', '⚠ Not Supported', 'Browser notifications not supported.'); return;
  }
  Notification.requestPermission().then(perm => {
    state.notifGranted = perm === 'granted';
    if (state.notifGranted) {
      notifBtn.classList.add('active');
      toast('success', '🔔 Alerts Enabled', 'You will receive push notifications.');
    } else {
      toast('warn', '🔕 Denied', 'Enable notifications in browser settings.');
    }
  });
}

function sendPushNotification(handle, label, tweet) {
  if (!state.notifGranted) return;
  const n = new Notification(`🚨 SpyX: @${handle} posted a coin!`, {
    body: `${label}\n${tweet.slice(0, 80)}...`,
    icon: 'https://abs.twimg.com/responsive-web/client-web/icon-svg.168b89d5.svg',
    badge: 'https://abs.twimg.com/responsive-web/client-web/icon-svg.168b89d5.svg',
  });
  n.onclick = () => { window.focus(); n.close(); };
  setTimeout(() => n.close(), 8000);
}

// ── TOAST ──────────────────────────────────────────────────
function toast(type, title, msg) {
  const icons = { success:'✓', danger:'🚨', warn:'⚠', info:'ℹ' };
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `
    <div class="toast-icon">${icons[type] || 'ℹ'}</div>
    <div class="toast-body">
      <div class="toast-title">${title}</div>
      <div class="toast-msg">${msg}</div>
    </div>
  `;
  toastContainer.appendChild(el);
  setTimeout(() => {
    el.style.animation = 'toastOut .3s ease forwards';
    setTimeout(() => el.remove(), 300);
  }, 4500);
}

// ── STATUS ─────────────────────────────────────────────────
function setStatus(s) {
  statusBadge.className = `status-badge${s === 'live' ? ' live' : ''}`;
  statusText.textContent = s === 'live' ? 'LIVE' : 'OFFLINE';
}

// ── QUICK DEX SEARCH ───────────────────────────────────────
function quickDexSearch() {
  const q = dexInput.value.trim();
  if (!q) { toast('warn', '⚠ Empty', 'Enter a contract address or ticker.'); return; }
  window.open(`https://dexscreener.com/search?q=${encodeURIComponent(q)}`, '_blank');
}

// ── HELPERS ────────────────────────────────────────────────
function formatTime(date) {
  return date.toLocaleTimeString('en-US', { hour12: false, hour:'2-digit', minute:'2-digit', second:'2-digit' });
}

function formatInterval(s) {
  return s < 60 ? `${s}s` : `${s/60}m`;
}

// ── PERSIST STATE ──────────────────────────────────────────
function saveState() {
  try {
    localStorage.setItem('spyx_tracked', JSON.stringify(state.tracked));
    localStorage.setItem('spyx_feed', JSON.stringify(state.feedItems.slice(0, 100)));
  } catch(e) {}
}

function loadState() {
  try {
    const t = localStorage.getItem('spyx_tracked');
    if (t) state.tracked = JSON.parse(t);
    const f = localStorage.getItem('spyx_feed');
    if (f) {
      state.feedItems = JSON.parse(f).map(i => ({ ...i, timestamp: new Date(i.timestamp) }));
    }
  } catch(e) {}
  renderFeed();
}

// ── SIMULATION ENGINE ──────────────────────────────────────
// Realistic mock tweets with CAs and tickers for demo/testing.

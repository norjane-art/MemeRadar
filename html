<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Xspyto — Twitter CA Tracker</title>
  <link rel="stylesheet" href="style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet"/>
</head>
<body>

  <div class="bg-grid"></div>
  <div class="scanline"></div>

  <header>
    <div class="logo">
      <span class="logo-icon">⬡</span>
      <span class="logo-text">X<span class="accent">SPYTO</span></span>
    </div>
    <div class="header-right">
      <div class="notif-toggle" id="notifToggle" title="Enable push notifications">
        <span class="notif-icon">🔔</span>
        <span class="notif-label" id="notifLabel">NOTIFICATIONS OFF</span>
      </div>
      <div class="status-dot" id="statusDot"></div>
      <span class="status-text" id="statusText">IDLE</span>
    </div>
  </header>

  <main>

    <!-- LEFT: ADD TRACKER + DEX QUICK LAUNCH -->
    <section class="panel panel-left">
      <h2 class="panel-title">[ ADD ACCOUNT ]</h2>

      <div class="input-group">
        <label>TWITTER @ HANDLE</label>
        <div class="input-row">
          <span class="at-symbol">@</span>
          <input type="text" id="handleInput" placeholder="elonmusk" maxlength="50" autocomplete="off"/>
        </div>
      </div>

      <div class="input-group">
        <label>LABEL <span class="optional">(optional)</span></label>
        <input type="text" id="labelInput" placeholder="e.g. Alpha Caller" maxlength="40" autocomplete="off"/>
      </div>

      <button class="btn-add" id="addBtn">
        <span>+ TRACK ACCOUNT</span>
      </button>

      <div class="divider"></div>

      <h2 class="panel-title">[ DEX / TERMINALS ]</h2>
      <p class="hint">Paste a contract address or ticker, then tap a platform:</p>

      <div class="input-group">
        <label>CONTRACT ADDRESS / TICKER</label>
        <input type="text" id="caInput" placeholder="0x... or $PEPE or So1111..." autocomplete="off"/>
      </div>

      <div class="section-label">◈ DEX SCREENERS</div>
      <div class="dex-buttons" id="dexScreeners">
        <button class="dex-btn" onclick="openDex('dexscreener')">
          <span class="dex-icon">📊</span> DEX SCREENER
        </button>
        <button class="dex-btn" onclick="openDex('dextools')">
          <span class="dex-icon">🔧</span> DEXTOOLS
        </button>
        <button class="dex-btn" onclick="openDex('birdeye')">
          <span class="dex-icon">🦅</span> BIRDEYE
        </button>
        <button class="dex-btn" onclick="openDex('geckoterminal')">
          <span class="dex-icon">🦎</span> GECKO TERMINAL
        </button>
        <button class="dex-btn" onclick="openDex('defined')">
          <span class="dex-icon">📐</span> DEFINED.FI
        </button>
      </div>

      <div class="section-label">◈ TRADING TERMINALS</div>
      <div class="dex-buttons">
        <button class="dex-btn" onclick="openDex('gmgn')">
          <span class="dex-icon">◆</span> GMGN.AI
        </button>
        <button class="dex-btn" onclick="openDex('axiom')">
          <span class="dex-icon">⬡</span> AXIOM
        </button>
        <button class="dex-btn" onclick="openDex('bullx')">
          <span class="dex-icon">🐂</span> BULLX
        </button>
        <button class="dex-btn" onclick="openDex('photon')">
          <span class="dex-icon">⚡</span> PHOTON
        </button>
        <button class="dex-btn" onclick="openDex('trojan')">
          <span class="dex-icon">🐴</span> TROJAN
        </button>
        <button class="dex-btn" onclick="openDex('maestro')">
          <span class="dex-icon">🎯</span> MAESTRO
        </button>
        <button class="dex-btn" onclick="openDex('banana')">
          <span class="dex-icon">🍌</span> BANANA GUN
        </button>
        <button class="dex-btn" onclick="openDex('bloom')">
          <span class="dex-icon">🌸</span> BLOOM
        </button>
        <button class="dex-btn" onclick="openDex('nova')">
          <span class="dex-icon">🌟</span> NOVA
        </button>
        <button class="dex-btn" onclick="openDex('soltradingbot')">
          <span class="dex-icon">🤖</span> SOL TRADING BOT
        </button>
      </div>

      <div class="section-label">◈ WALLETS</div>
      <div class="dex-buttons">
        <button class="dex-btn" onclick="openDex('phantom')">
          <span class="dex-icon">👻</span> PHANTOM
        </button>
        <button class="dex-btn" onclick="openDex('raydium')">
          <span class="dex-icon">⚛️</span> RAYDIUM
        </button>
        <button class="dex-btn" onclick="openDex('jupiter')">
          <span class="dex-icon">🪐</span> JUPITER
        </button>
        <button class="dex-btn" onclick="openDex('uniswap')">
          <span class="dex-icon">🦄</span> UNISWAP
        </button>
      </div>
    </section>

    <!-- CENTER: LIVE FEED -->
    <section class="panel panel-center">
      <div class="feed-header">
        <h2 class="panel-title">[ LIVE FEED ]</h2>
        <div class="feed-controls">
          <button class="btn-sim" id="simBtn" title="Simulate a detection for demo">⚡ SIMULATE</button>
          <button class="btn-clear" id="clearFeedBtn">✕ CLEAR</button>
        </div>
      </div>

      <div class="ticker-bar" id="tickerBar">
        <span class="ticker-inner" id="tickerInner">XSPYTO MONITORING ACTIVE — WAITING FOR SIGNALS...</span>
      </div>

      <div class="feed" id="feed">
        <div class="feed-empty" id="feedEmpty">
          <div class="radar-anim">
            <div class="radar-ring r1"></div>
            <div class="radar-ring r2"></div>
            <div class="radar-ring r3"></div>
            <div class="radar-dot"></div>
          </div>
          <p>Xspyto radar is live.<br/>Add accounts to begin tracking.</p>
        </div>
      </div>
    </section>

    <!-- RIGHT: TRACKED ACCOUNTS + TG BOTS -->
    <section class="panel panel-right">
      <div class="panel-title-row">
        <h2 class="panel-title">[ TRACKING ]</h2>
        <span class="account-count" id="accountCount">0 accounts</span>
      </div>

      <div class="accounts-list" id="accountsList">
        <div class="no-accounts">No accounts tracked yet.</div>
      </div>

      <div class="divider"></div>

      <h2 class="panel-title">[ DETECTED CA/TICKERS ]</h2>
      <div class="detected-list" id="detectedList">
        <div class="no-detected">Nothing detected yet.</div>
      </div>

      <div class="divider"></div>

      <h2 class="panel-title">[ TELEGRAM TRADING BOTS ]</h2>
      <p class="hint">Tap to open bot in Telegram. Paste CA there to trade.</p>

      <div class="tg-bots-grid" id="tgBotsGrid">

        <div class="tg-section-label">⚡ SOLANA BOTS</div>

        <button class="tg-btn" onclick="openTgBot('trojanbot')">
          <div class="tg-btn-inner">
            <span class="tg-icon">🐴</span>
            <div class="tg-info">
              <span class="tg-name">Trojan on Solana</span>
              <span class="tg-desc">Fast sniper · limit orders</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <button class="tg-btn" onclick="openTgBot('bananagunbot')">
          <div class="tg-btn-inner">
            <span class="tg-icon">🍌</span>
            <div class="tg-info">
              <span class="tg-name">Banana Gun</span>
              <span class="tg-desc">Auto-snipe · copy trade</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <button class="tg-btn" onclick="openTgBot('pepeboostbot')">
          <div class="tg-btn-inner">
            <span class="tg-icon">🐸</span>
            <div class="tg-info">
              <span class="tg-name">Pepe Boost</span>
              <span class="tg-desc">Sol sniper · instant buy</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <button class="tg-btn" onclick="openTgBot('soltradingbot')">
          <div class="tg-btn-inner">
            <span class="tg-icon">🤖</span>
            <div class="tg-info">
              <span class="tg-name">Sol Trading Bot</span>
              <span class="tg-desc">DEX aggregator · DCA</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <button class="tg-btn" onclick="openTgBot('photonbot')">
          <div class="tg-btn-inner">
            <span class="tg-icon">⚡</span>
            <div class="tg-info">
              <span class="tg-name">Photon</span>
              <span class="tg-desc">Speed sniper · meme trader</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <button class="tg-btn" onclick="openTgBot('novabot')">
          <div class="tg-btn-inner">
            <span class="tg-icon">🌟</span>
            <div class="tg-info">
              <span class="tg-name">Nova Bot</span>
              <span class="tg-desc">Copy trade · wallet track</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <button class="tg-btn" onclick="openTgBot('bloombot')">
          <div class="tg-btn-inner">
            <span class="tg-icon">🌸</span>
            <div class="tg-info">
              <span class="tg-name">Bloom</span>
              <span class="tg-desc">Anti-rug · auto-sell</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <div class="tg-section-label">🔷 EVM / ETH BOTS</div>

        <button class="tg-btn" onclick="openTgBot('maestrob')">
          <div class="tg-btn-inner">
            <span class="tg-icon">🎯</span>
            <div class="tg-info">
              <span class="tg-name">Maestro Sniper</span>
              <span class="tg-desc">ETH/BSC/ARB sniper</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <button class="tg-btn" onclick="openTgBot('unibot')">
          <div class="tg-btn-inner">
            <span class="tg-icon">🦄</span>
            <div class="tg-info">
              <span class="tg-name">Unibot</span>
              <span class="tg-desc">Ethereum sniper · limit</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <button class="tg-btn" onclick="openTgBot('waiebot')">
          <div class="tg-btn-inner">
            <span class="tg-icon">🤖</span>
            <div class="tg-info">
              <span class="tg-name">W.A.I.E Bot</span>
              <span class="tg-desc">Multi-chain auto trade</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <button class="tg-btn" onclick="openTgBot('mevbot')">
          <div class="tg-btn-inner">
            <span class="tg-icon">⚔️</span>
            <div class="tg-info">
              <span class="tg-name">MEV Bot</span>
              <span class="tg-desc">Frontrun · sandwich</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <div class="tg-section-label">📊 ANALYTICS BOTS</div>

        <button class="tg-btn" onclick="openTgBot('gmgnbot')">
          <div class="tg-btn-inner">
            <span class="tg-icon">◆</span>
            <div class="tg-info">
              <span class="tg-name">GMGN Bot</span>
              <span class="tg-desc">Smart money tracker</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <button class="tg-btn" onclick="openTgBot('degenalpha')">
          <div class="tg-btn-inner">
            <span class="tg-icon">🔍</span>
            <div class="tg-info">
              <span class="tg-name">Degen Alpha</span>
              <span class="tg-desc">Wallet spy · KOL tracker</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

        <button class="tg-btn" onclick="openTgBot('solsniffer')">
          <div class="tg-btn-inner">
            <span class="tg-icon">🛡️</span>
            <div class="tg-info">
              <span class="tg-name">Sol Sniffer</span>
              <span class="tg-desc">Rug check · audit token</span>
            </div>
            <span class="tg-arrow">→</span>
          </div>
        </button>

      </div>

    </section>

  </main>

  <!-- TOAST -->
  <div class="toast" id="toast"></div>

  <!-- ALERT MODAL -->
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal" id="modal">
      <div class="modal-badge">🚨 CA DETECTED</div>
      <h3 class="modal-handle" id="modalHandle">@account</h3>
      <p class="modal-text" id="modalText">just posted:</p>
      <div class="modal-ca" id="modalCA"></div>
      <p class="modal-type" id="modalType"></p>

      <div class="modal-section-label">DEX SCREENERS</div>
      <div class="modal-dex-row">
        <button class="dex-btn sm" onclick="openDexFromModal('dexscreener')">DEX SCREENER</button>
        <button class="dex-btn sm" onclick="openDexFromModal('dextools')">DEXTOOLS</button>
        <button class="dex-btn sm" onclick="openDexFromModal('birdeye')">BIRDEYE</button>
        <button class="dex-btn sm" onclick="openDexFromModal('geckoterminal')">GECKO</button>
      </div>

      <div class="modal-section-label">TRADING TERMINALS</div>
      <div class="modal-dex-row">
        <button class="dex-btn sm" onclick="openDexFromModal('gmgn')">GMGN</button>
        <button class="dex-btn sm" onclick="openDexFromModal('axiom')">AXIOM</button>
        <button class="dex-btn sm" onclick="openDexFromModal('bullx')">BULLX</button>
        <button class="dex-btn sm" onclick="openDexFromModal('photon')">PHOTON</button>
        <button class="dex-btn sm" onclick="openDexFromModal('trojan')">TROJAN</button>
        <button class="dex-btn sm" onclick="openDexFromModal('banana')">BANANA</button>
      </div>

      <div class="modal-section-label">TELEGRAM BOTS — QUICK FIRE</div>
      <div class="modal-dex-row">
        <button class="dex-btn sm tg-modal-btn" onclick="openTgBotWithCA('trojanbot')">🐴 TROJAN</button>
        <button class="dex-btn sm tg-modal-btn" onclick="openTgBotWithCA('bananagunbot')">🍌 BANANA</button>
        <button class="dex-btn sm tg-modal-btn" onclick="openTgBotWithCA('photonbot')">⚡ PHOTON</button>
        <button class="dex-btn sm tg-modal-btn" onclick="openTgBotWithCA('maestrob')">🎯 MAESTRO</button>
        <button class="dex-btn sm tg-modal-btn" onclick="openTgBotWithCA('bloombot')">🌸 BLOOM</button>
        <button class="dex-btn sm tg-modal-btn" onclick="openTgBotWithCA('novabot')">🌟 NOVA</button>
      </div>

      <button class="modal-close" id="modalClose">DISMISS</button>
    </div>
  </div>

  <script src="app.js"></script>
</body>
</html>

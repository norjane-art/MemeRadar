<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MemeSpy — Crypto Twitter Tracker</title>
  <link rel="stylesheet" href="styles.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;600;700&family=Orbitron:wght@700;900&display=swap" rel="stylesheet" />
  <link rel="manifest" href="manifest.json" />
</head>
<body>

  <!-- BACKGROUND GRID -->
  <div class="bg-grid"></div>
  <div class="bg-scanlines"></div>
  <div class="bg-glow"></div>

  <!-- HEADER -->
  <header class="header">
    <div class="logo">
      <span class="logo-icon">🛰️</span>
      <span class="logo-text">MEME<span class="logo-accent">SPY</span></span>
    </div>
    <div class="header-status">
      <span class="status-dot" id="statusDot"></span>
      <span class="status-label" id="statusLabel">OFFLINE</span>
    </div>
    <div class="header-actions">
      <button class="btn-notif" id="notifBtn" title="Enable Notifications">
        <span class="notif-icon">🔔</span>
        <span class="notif-text">Alerts</span>
      </button>
    </div>
  </header>

  <!-- MAIN LAYOUT -->
  <main class="main">

    <!-- LEFT PANEL: ADD ACCOUNTS -->
    <section class="panel panel-left">
      <div class="panel-header">
        <span class="panel-title">📡 TRACK ACCOUNTS</span>
      </div>

      <div class="add-account-form">
        <div class="input-group">
          <span class="input-prefix">@</span>
          <input type="text" id="accountInput" placeholder="username" autocomplete="off" spellcheck="false" />
        </div>
        <button class="btn-primary" id="addAccountBtn">+ ADD</button>
      </div>

      <div class="tracked-list" id="trackedList">
        <!-- Tracked accounts inserted by JS -->
        <div class="empty-state" id="emptyState">
          <div class="empty-icon">🔍</div>
          <div class="empty-text">No accounts tracked yet.<br/>Add a Twitter/X handle above.</div>
        </div>
      </div>

      <div class="polling-controls">
        <label class="poll-label">Poll Interval</label>
        <div class="poll-options">
          <button class="poll-btn active" data-interval="30">30s</button>
          <button class="poll-btn" data-interval="60">1m</button>
          <button class="poll-btn" data-interval="120">2m</button>
          <button class="poll-btn" data-interval="300">5m</button>
        </div>
      </div>
    </section>

    <!-- CENTER PANEL: LIVE FEED -->
    <section class="panel panel-center">
      <div class="panel-header">
        <span class="panel-title">⚡ LIVE SIGNAL FEED</span>
        <button class="btn-clear" id="clearFeedBtn">CLEAR</button>
      </div>

      <div class="feed" id="feed">
        <div class="feed-empty" id="feedEmpty">
          <div class="radar-ring"></div>
          <div class="feed-empty-text">Awaiting signals...</div>
        </div>
      </div>
    </section>

    <!-- RIGHT PANEL: TRADING TERMINALS -->
    <section class="panel panel-right">
      <div class="panel-header">
        <span class="panel-title">💹 TRADING TERMINALS</span>
      </div>

      <div class="terminal-search">
        <input type="text" id="caInput" placeholder="Paste contract address / ticker..." autocomplete="off" />
        <button class="btn-primary" id="searchCaBtn">GO</button>
      </div>

      <div class="terminal-grid" id="terminalGrid">
        <!-- Generated by JS -->
      </div>
    </section>

  </main>

  <!-- NOTIFICATION TOAST CONTAINER -->
  <div class="toast-container" id="toastContainer"></div>

  <!-- SIGNAL DETAIL MODAL -->
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal" id="modal">
      <button class="modal-close" id="modalClose">✕</button>
      <div class="modal-content" id="modalContent"></div>
    </div>
  </div>

  <script src="app.js"></script>
</body>
</html>
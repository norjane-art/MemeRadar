          // Demo notification after 3s
          setTimeout(() => {
            new Notification('🚨 SpyXto Alert!', {
              body: '@cryptowhale just posted a contract address on Pump.fun!',
              icon: 'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><rect width="100" height="100" rx="20" fill="%231d9bf0"/><text y=".9em" font-size="70" x="12">SX</text></svg>'
            });
          }, 3000);
        } else {
          showToast('⚠️', 'Notifications Blocked', 'Please enable notifications in your browser settings.');
        }
      });
    } else {
      showToast('ℹ️', 'Not Supported', 'Your browser does not support push notifications.');
    }
  }

  // ADD ACCOUNT
  function addAccount() {
    const input = document.getElementById('trackInput');
    let val = input.value.trim();
    if (!val) return;

    // Extract handle
    if (val.includes('x.com/') || val.includes('twitter.com/')) {
      val = '@' + val.split('/').filter(Boolean).pop();
    }
    if (!val.startsWith('@')) val = '@' + val;

    const list = document.getElementById('accountsList');
    const card = document.createElement('div');
    card.className = 'account-card';
    const initial = val[1].toUpperCase();
    const colors = ['#1d9bf0','#9945FF','#00d084','#f7c948','#ff6b35'];
    const col = colors[Math.floor(Math.random() * colors.length)];
    card.innerHTML = `
      <div class="account-avatar" style="background:${col}">${initial}</div>
      <div class="account-info">
        <div class="account-name">${val}</div>
        <div class="account-handle">${val.toLowerCase()}</div>
      </div>
      <div class="account-status">
        <div class="status-dot status-dot-live"></div>
        <span style="color:var(--green)">TRACKING</span>
      </div>
    `;
    card.onclick = () => window.open(`https://x.com/${val.replace('@','')}`, '_blank');
    list.appendChild(card);
    input.value = '';
    showToast('✅', 'Account Added!', `Now tracking ${val} for contract address posts.`);
  }

  // TRADE MODAL (demo - shows options)
  function showTradeModal(e, platform) {
    e.preventDefault();
    showToast('🚀', `Trading on ${platform}`, 'Click any platform button to open the trading page directly.');
  }

  // TOAST
  function showToast(icon, title, msg) {
    const container = document.getElementById('toastContainer');
    const toast = document.createElement('div');
    toast.className = 'toast';
    toast.innerHTML = `
      <div class="toast-icon">${icon}</div>
      <div class="toast-content">
        <div class="toast-title">${title}</div>
        <div class="toast-msg">${msg}</div>
      </div>
    `;
    container.appendChild(toast);
    setTimeout(() => {
      toast.style.opacity = '0';
      toast.style.transform = 'translateX(20px)';
      toast.style.transition = 'all 0.3s';
      setTimeout(() => toast.remove(), 300);
    }, 4000);
  }

  // DEMO: simulate live CA alert after 8 seconds
  setTimeout(() => {
    showToast('🚨', 'New CA Detected!', '@cryptowhale just posted: 7xKXtg2CW87... on Pump.fun — click to trade!');
  }, 8000);

  // Enter key on input
  document.getElementById('trackInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') addAccount();
  });
</script>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SpyXto — Track. Trade. Dominate.</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #000000;
    --white: #ffffff;
    --x-blue: #1d9bf0;
    --x-blue-dim: #1a8cd8;
    --green: #00d084;
    --red: #ff4444;
    --gold: #f7c948;
    --bg: #000000;
    --surface: #0f0f0f;
    --surface2: #161616;
    --border: #2f3336;
    --text-muted: #71767b;
    --text-secondary: #e7e9ea;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Syne', sans-serif;
    background: var(--bg);
    color: var(--white);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* NOISE OVERLAY */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
    opacity: 0.4;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(0,0,0,0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .logo-icon {
    width: 36px;
    height: 36px;
    background: var(--x-blue);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 16px;
    color: #fff;
    letter-spacing: -1px;
  }

  .logo-text {
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.5px;
  }

  .logo-text span { color: var(--x-blue); }

  .nav-actions {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .btn {
    padding: 8px 18px;
    border-radius: 9999px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 14px;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .btn-primary {
    background: var(--x-blue);
    color: #fff;
  }

  .btn-primary:hover { background: var(--x-blue-dim); transform: translateY(-1px); }

  .btn-outline {
    background: transparent;
    color: var(--white);
    border: 1px solid var(--border);
  }

  .btn-outline:hover { background: rgba(255,255,255,0.05); }

  .btn-green {
    background: var(--green);
    color: #000;
  }
  .btn-green:hover { opacity: 0.9; transform: translateY(-1px); }

  .btn-gold {
    background: var(--gold);
    color: #000;
  }
  .btn-gold:hover { opacity: 0.9; transform: translateY(-1px); }

  /* WALLET CONNECT BTN */
  .wallet-btn {
    background: linear-gradient(135deg, #9945FF, #14F195);
    color: #fff;
    padding: 8px 16px;
    border-radius: 9999px;
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .wallet-btn:hover { opacity: 0.9; transform: scale(1.03); }

  /* HERO */
  .hero {
    padding: 120px 24px 80px;
    text-align: center;
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(29,155,240,0.1);
    border: 1px solid rgba(29,155,240,0.3);
    color: var(--x-blue);
    padding: 6px 14px;
    border-radius: 9999px;
    font-size: 12px;
    font-family: 'Space Mono', monospace;
    margin-bottom: 28px;
    letter-spacing: 0.5px;
  }

  .pulse-dot {
    width: 7px;
    height: 7px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 1.5s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.7); }
  }

  h1 {
    font-size: clamp(42px, 8vw, 80px);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -2px;
    margin-bottom: 20px;
  }

  h1 .accent { color: var(--x-blue); }
  h1 .accent2 { color: var(--green); }

  .hero-desc {
    font-size: 17px;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 620px;
    margin: 0 auto 36px;
    font-weight: 400;
  }

  .hero-desc strong { color: var(--text-secondary); }

  .hero-cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* TICKER TAPE */
  .ticker {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 10px 0;
    overflow: hidden;
    position: relative;
    z-index: 1;
    margin-bottom: 60px;
  }

  .ticker-inner {
    display: flex;
    gap: 40px;
    animation: ticker 25s linear infinite;
    white-space: nowrap;
    width: max-content;
  }

  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .ticker-item {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ticker-item .up { color: var(--green); }
  .ticker-item .down { color: var(--red); }

  /* SECTION */
  section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px 80px;
    position: relative;
    z-index: 1;
  }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 11px;
    color: var(--x-blue);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    letter-spacing: -1px;
    margin-bottom: 40px;
  }

  /* TRACKER SECTION */
  .tracker-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 20px;
  }

  .tracker-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .tracker-title {
    font-size: 18px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .x-icon {
    width: 28px;
    height: 28px;
    background: #000;
    border: 1px solid var(--border);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .x-icon svg { width: 16px; height: 16px; fill: white; }

  .tracker-input-row {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
  }

  .input-field {
    flex: 1;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 13px;
    outline: none;
    transition: border-color 0.2s;
  }

  .input-field:focus { border-color: var(--x-blue); }
  .input-field::placeholder { color: var(--text-muted); }

  /* FOLLOWED ACCOUNTS */
  .accounts-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .account-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    transition: border-color 0.2s, background 0.2s;
    cursor: pointer;
  }

  .account-card:hover { border-color: var(--x-blue); background: rgba(29,155,240,0.05); }

  .account-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--x-blue), var(--green));
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 15px;
    flex-shrink: 0;
  }

  .account-info { flex: 1; }
  .account-name { font-weight: 700; font-size: 14px; }
  .account-handle { color: var(--text-muted); font-size: 12px; font-family: 'Space Mono', monospace; }

  .account-status {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-family: 'Space Mono', monospace;
  }

  .status-dot-live { background: var(--green); }
  .status-dot-idle { background: var(--text-muted); }

  .status-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    animation: pulse 1.8s infinite;
  }

  /* ALERT CARD */
  .alert-card {
    background: rgba(0, 208, 132, 0.06);
    border: 1px solid rgba(0, 208, 132, 0.25);
    border-radius: 12px;
    padding: 16px 18px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
    margin-top: 10px;
    cursor: pointer;
    transition: background 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .alert-card:hover { background: rgba(0, 208, 132, 0.1); }

  .alert-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .alert-badge {
    background: var(--green);
    color: #000;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 10px;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .alert-badge.pump { background: #ff6b35; color: #fff; }
  .alert-badge.ray { background: #9945FF; color: #fff; }

  .alert-handle {
    font-size: 13px;
    font-family: 'Space Mono', monospace;
    color: var(--x-blue);
  }

  .alert-time {
    font-size: 11px;
    color: var(--text-muted);
    font-family: 'Space Mono', monospace;
    margin-left: auto;
  }

  .alert-ca {
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    color: var(--green);
    background: rgba(0,208,132,0.08);
    padding: 6px 10px;
    border-radius: 6px;
    margin-bottom: 10px;
    word-break: break-all;
  }

  .alert-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .trade-btn {
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 11px;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    cursor: pointer;
    border: none;
    text-decoration: none;
    transition: all 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .trade-btn:hover { transform: translateY(-1px); opacity: 0.9; }
  .trade-btn.pump { background: #ff6b35; color: #fff; }
  .trade-btn.axiom { background: #7c3aed; color: #fff; }
  .trade-btn.gmgn { background: #059669; color: #fff; }
  .trade-btn.photon { background: #ea580c; color: #fff; }
  .trade-btn.bullx { background: #2563eb; color: #fff; }
  .trade-btn.raydium { background: #9945FF; color: #fff; }

  /* TRADING PLATFORMS GRID */
  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 14px;
  }

  .platform-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    text-align: center;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
    display: block;
  }

  .platform-card:hover { border-color: var(--x-blue); transform: translateY(-3px); background: var(--surface2); }

  .platform-icon {
    width: 52px;
    height: 52px;
    border-radius: 12px;
    margin: 0 auto 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
  }

  .platform-name {
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 4px;
  }

  .platform-desc {
    font-size: 11px;
    color: var(--text-muted);
    font-family: 'Space Mono', monospace;
    line-height: 1.5;
  }

  /* TELEGRAM BOTS */
  .bots-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 14px;
  }

  .bot-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
    display: block;
  }

  .bot-card:hover { border-color: #24A1DE; transform: translateY(-3px); }

  .bot-icon {
    width: 46px;
    height: 46px;
    border-radius: 10px;
    background: rgba(36,161,222,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    margin-bottom: 12px;
  }

  .bot-name { font-weight: 700; font-size: 14px; margin-bottom: 4px; }
  .bot-desc { font-size: 11px; color: var(--text-muted); font-family: 'Space Mono', monospace; line-height: 1.5; }

  .telegram-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: rgba(36,161,222,0.1);
    border: 1px solid rgba(36,161,222,0.3);
    color: #24A1DE;
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 10px;
    font-family: 'Space Mono', monospace;
    margin-top: 8px;
  }

  /* BURN SECTION */
  .burn-box {
    background: linear-gradient(135deg, rgba(255,68,68,0.08), rgba(247,201,72,0.08));
    border: 1px solid rgba(255,68,68,0.3);
    border-radius: 16px;
    padding: 32px;
  }

  .burn-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
  }

  .burn-icon {
    font-size: 36px;
  }

  .burn-title { font-size: 22px; font-weight: 800; }
  .burn-subtitle { color: var(--text-muted); font-size: 13px; font-family: 'Space Mono', monospace; }

  .burn-instructions {
    background: rgba(0,0,0,0.3);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 18px;
    margin-bottom: 20px;
  }

  .burn-instructions p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 8px;
  }

  .burn-instructions p:last-child { margin-bottom: 0; }

  .burn-instructions strong { color: var(--red); }

  .burn-step {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 10px;
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .step-num {
    background: var(--red);
    color: #fff;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* WALLET MODAL */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.85);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px;
    max-width: 420px;
    width: 90%;
    position: relative;
    animation: modalIn 0.25s ease;
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: var(--surface2);
    border: 1px solid var(--border);
    color: #fff;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    transition: background 0.15s;
  }

  .modal-close:hover { background: rgba(255,255,255,0.1); }

  .modal-title { font-size: 20px; font-weight: 800; margin-bottom: 6px; }
  .modal-subtitle { font-size: 13px; color: var(--text-muted); margin-bottom: 24px; font-family: 'Space Mono', monospace; }

  .wallet-option {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 14px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
    cursor: pointer;
    transition: all 0.15s;
    text-decoration: none;
    color: inherit;
  }

  .wallet-option:hover { border-color: #9945FF; background: rgba(153,69,255,0.08); }

  .wallet-logo {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }

  .wallet-name { font-weight: 700; font-size: 14px; }
  .wallet-chain { font-size: 11px; color: var(--text-muted); font-family: 'Space Mono', monospace; }

  .wallet-arrow { margin-left: auto; color: var(--text-muted); font-size: 18px; }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    padding: 40px 24px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .footer-logo { font-size: 28px; font-weight: 800; letter-spacing: -1px; margin-bottom: 10px; }
  .footer-logo span { color: var(--x-blue); }

  .footer-desc {
    color: var(--text-muted);
    font-size: 13px;
    font-family: 'Space Mono', monospace;
    max-width: 500px;
    margin: 0 auto 24px;
    line-height: 1.7;
  }

  .footer-links {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .footer-link {
    color: var(--text-muted);
    font-size: 13px;
    text-decoration: none;
    transition: color 0.15s;
    font-family: 'Space Mono', monospace;
  }

  .footer-link:hover { color: var(--white); }

  /* TWITTER / X LINK BLOCK */
  .x-creator-card {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px 18px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
    margin-bottom: 24px;
  }

  .x-creator-card:hover { border-color: var(--x-blue); background: rgba(29,155,240,0.05); }

  .x-creator-avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--x-blue), #9945FF);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 16px;
  }

  .x-creator-name { font-weight: 700; font-size: 14px; }
  .x-creator-handle { font-size: 11px; color: var(--x-blue); font-family: 'Space Mono', monospace; }

  .copyright {
    font-size: 11px;
    color: var(--text-muted);
    font-family: 'Space Mono', monospace;
  }

  /* DIVIDER */
  .divider {
    height: 1px;
    background: var(--border);
    margin: 0 24px 60px;
  }

  /* NOTIFICATION TOAST */
  .toast-container {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 999;
    display: flex;
    flex-direction: column;
    gap: 10px;
    pointer-events: none;
  }

  .toast {
    background: var(--surface);
    border: 1px solid var(--green);
    border-radius: 12px;
    padding: 14px 18px;
    max-width: 320px;
    pointer-events: all;
    animation: toastIn 0.3s ease;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  @keyframes toastIn {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .toast-icon { font-size: 18px; flex-shrink: 0; }
  .toast-content { flex: 1; }
  .toast-title { font-weight: 700; font-size: 13px; margin-bottom: 3px; }
  .toast-msg { font-size: 11px; color: var(--text-muted); font-family: 'Space Mono', monospace; line-height: 1.5; }

  /* RESPONSIVE */
  @media (max-width: 640px) {
    nav { padding: 0 14px; }
    .hero { padding: 100px 14px 60px; }
    section { padding: 0 14px 60px; }
    .tracker-input-row { flex-direction: column; }
    .nav-actions .btn-outline { display: none; }
